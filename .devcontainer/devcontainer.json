{
    "name": "SAMoS Dev Container",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "postCreateCommand": "bash .devcontainer/build-samos.sh",
    "extensions": [
        "ms-vscode.cpptools"
    ],
    "remoteEnv": {
        "PATH": "${containerEnv:PATH}:${HOME}/samos/bin",
        "PYTHONPATH": "${PYTHONPATH}:${HOME}/samos/analysis"
    }
}
